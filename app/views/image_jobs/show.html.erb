<main class='container-fluid'>
  <h2>Image Alt-Text Job Details</h2>
  <ul data-controller="job"
          data-job-id="<%= @image_job.id %>"
          data-job-status="<%= @image_job.status %>"
          data-job-finished-at="<%= @image_job.finished_at&.iso8601 %>"
          data-job-alt-text="<%= @image_job.alt_text %>"
          data-job-processing-error-message="<%= @image_job.processing_error_message %>"
          id="<%= dom_id @image_job %>">
            <li><strong>File Name:</strong> <%= @image_job.object_key %> </li>

    <li><strong>Job ID:</strong> <%= @image_job.uuid %></li>
    <li><strong>Started At:</strong> <%= @image_job.created_at.getlocal.strftime("%b %e, %Y %l:%M %p") if @image_job.created_at %></li>
    <li><strong>Finished At:</strong> <span data-job-target="finishedAt"></span></li>
    <li><strong>Status:</strong> <span data-job-target="status"></span></li>
    <li><strong>Alt Text:</strong> <span data-job-target="altText"></li>
    <span data-job-target="processingErrorMessage"></span>
  </ul>

  <%= link_to '<< Image Jobs List', image_jobs_path %>
</main>
