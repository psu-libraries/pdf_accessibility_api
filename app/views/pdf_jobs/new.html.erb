<main class="container-fluid">
  <% pages_used = @current_user.total_pages_processed_last_24_hours %>
  <% page_limit = @unit&.user_daily_page_limit || 50 %>
  <% pages_left = page_limit - pages_used %>
  <% if pages_left < 0 %>
    <% pages_left = 0 %>
  <% end %>
  <% flash.each do |_, msg| %>
    <div class='alert'>
      <%= msg %>
    </div>
  <% end %>
  <div class="row g-4">
    <%= render 'sidebar' %>
    <div class="region-content-wrapper col-lg-8 px-xl-5">
      <div>
        <h2><%= I18n.t('pdf.upload.heading') %></h2>
      </div>
      <div class="mb-3">
        <p><%= I18n.t('pdf.upload.remaining_pages', pages_used:, pages_left:)%></p>
      </div>
      <div>
        <strong><%= t('pdf.privacy_notice.header') %></strong>
        <ul>
          <li><%= t('pdf.privacy_notice.adobe') %></li>
          <li><%= t('pdf.privacy_notice.aws') %></li>
        </ul>
      </div>
      <section>
        <%= form_with url: pdf_jobs_path, id: 'file-uploader' do |form| %>
        <div
          data-controller="pdf-uppy"
          data-uppy-parent-form="file-uploader"></div>
        <% end %>
      </section>
    </div>
  </div>
</main>
